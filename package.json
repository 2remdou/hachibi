{
  "name": "hachibi",
  "version": "0.1.0",
  "description": "Build parallèle d'issues Markdown via worktrees git isolés + agents claude headless. Scaffold .hachibi/ éditable, lancé via tsx. Requiert un runtime Claude Code (CLI claude + skills /tdd, /review, /simplify).",
  "type": "module",
  "bin": {
    "hachibi": "bin/hachibi.js"
  },
  "exports": {
    ".": "./src/orchestrate.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "src",
    "template",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude",
    "claude-code",
    "orchestration",
    "agents",
    "worktree",
    "issues",
    "parallel",
    "tdd",
    "codegen"
  ],
  "license": "MIT",
  "dependencies": {
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
